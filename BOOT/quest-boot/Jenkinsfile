pipeline {
    agent any

    stages {
        stage('Maven Package') {
            agent {
                docker {
                    image 'maven:3.9-amazoncorretto-21'
                    args '-v /Users/mathieu/.m2:/root/.m2' // Pour garder le cache Maven
                    reuseNode true // Permet de partager le même workspace que l'agent Jenkins
                }
            }

            steps {
                dir('BOOT/quest-boot') {
                    sh 'mvn clean package'
                }
            }
        }

        stage('Docker build') {
            steps {
                dir('BOOT/quest-boot') {
                    sh 'docker build -t ajc/quest-boot .'
                }
            }
        }

        stage('Docker compose') {
            steps {
                dir('BOOT/quest-boot') {
                    sh 'docker compose up -d'
                }
            }
        }
    }
}