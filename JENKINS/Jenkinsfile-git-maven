pipeline {
    agent any

    // Configuration des outils à utiliser pour l'ensemble du Pipeline
    tools {
        // On dit qu'on veut l'outil Maven, id "maven-3.9.16"
        maven 'maven-3.9.16'
    }

    stages {
        stage('Git checkout') {
            steps {
                script {
                    git credentialsId: 'git-login-clea',
                        url: 'git@github.com:jabid021/AJC-JAVA-260407-GIT.git',
                        branch: 'clea'
                }
            }
        }

        stage('Maven Outils démonstration') {
            // Les outils pour le Stage (donc pour les étapes qui sont dans ce Stage)
            tools {
                maven 'maven-3.9.16'
            }

            steps {
                sh 'mvn -version'
            }
        }

        stage('Maven Package') {
            steps {
                dir('BOOT/quest-boot') {
                    sh 'mvn -version'
                    sh 'mvn clean package'
                }
            }
        }
    }
}