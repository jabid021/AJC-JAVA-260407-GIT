pipeline {
    agent {
        docker {
            image 'maven:3.9-amazoncorretto-21'
        }
    }

    stages {
        stage('Git checkout') {
            steps {
                git credentialsId: 'git-login-clea',
                    url: 'git@github.com:jabid021/AJC-JAVA-260407-GIT.git',
                    branch: 'clea'
            }
        }

        stage('Maven Docker démonstration') {
            steps {
                sh 'mvn -version'
            }
        }

        stage('Maven Package') {
            steps {
                dir('BOOT/quest-boot') {
                    sh 'mvn -version'
                    sh 'mvn clean package'
                }
            }
        }
    }
}